<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp"
        android:background="@drawable/bg_dialog_card">

        <!-- TITLE -->
        <TextView
            android:text="Booking Kendaraan"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#1A1A1A"
            android:layout_marginBottom="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- IMAGE -->
        <ImageView
            android:id="@+id/ivPreviewMobil"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:scaleType="centerInside"
            android:background="@drawable/bg_input"
            android:padding="10dp"
            android:src="@drawable/porsche"
            android:layout_marginBottom="16dp"/>

        <!-- NAMA -->
        <EditText
            android:id="@+id/etNama"
            android:hint="Nama Penyewa"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <!-- TANGGAL -->
        <EditText
            android:id="@+id/etTanggal"
            android:hint="Pilih tanggal"
            android:focusable="false"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <!-- JAM -->
        <EditText
            android:id="@+id/etJam"
            android:hint="Pilih jam"
            android:focusable="false"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input"
            android:padding="12dp"
            android:layout_marginBottom="12dp"/>

        <!-- DURASI -->
        <EditText
            android:id="@+id/etDurasi"
            android:hint="Durasi (hari)"
            android:inputType="number"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_input"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- TOTAL -->
        <TextView
            android:id="@+id/tvTotal"
            android:text="Total: Rp 0"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#00A651"
            android:layout_marginBottom="16dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- BUTTON -->
        <Button
            android:id="@+id/btnBooking"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Sewa Sekarang"
            android:textColor="#FFFFFF"
            android:backgroundTint="#00A651"/>

    </LinearLayout>
</ScrollView>
