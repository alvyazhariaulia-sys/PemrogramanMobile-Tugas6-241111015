package com.utama.aplikasikendarin

import android.content.ContentValues
import android.content.Context
import android.database.sqlite.SQLiteDatabase
import android.database.sqlite.SQLiteOpenHelper

class TransaksiDatabaseHelper(context: Context) :
    SQLiteOpenHelper(context, "transaksi_db", null, 2) { 

    companion object {
        const val TABLE = "transaksi"
        const val COL_ID = "id"
        const val COL_NAMA = "nama_kendaraan"
        const val COL_HARGA = "harga"
        const val COL_TANGGAL = "tanggal"
        const val COL_STATUS = "status"
        const val COL_METODE = "metode"
    }

    override fun onCreate(db: SQLiteDatabase) {
        val query = """
            CREATE TABLE $TABLE (
                $COL_ID INTEGER PRIMARY KEY AUTOINCREMENT,
                $COL_NAMA TEXT,
                $COL_HARGA TEXT,
                $COL_TANGGAL TEXT,
                $COL_STATUS TEXT,
                $COL_METODE TEXT
            )
        """.trimIndent()

        db.execSQL(query)
    }

    override fun onUpgrade(db: SQLiteDatabase, oldVersion: Int, newVersion: Int) {

        db.execSQL("DROP TABLE IF EXISTS $TABLE")
        onCreate(db)
    }

    fun insertTransaksi(transaksi: TransaksiEntity) {
        val db = writableDatabase
        val values = ContentValues().apply {
            put(COL_NAMA, transaksi.namaKendaraan)
            put(COL_HARGA, transaksi.harga)
            put(COL_TANGGAL, transaksi.tanggal)
            put(COL_STATUS, transaksi.status)
            put(COL_METODE, transaksi.metodePembayaran)
        }
        db.insert(TABLE, null, values)
    }

    fun getAllTransaksi(): List<TransaksiEntity> {
        val list = mutableListOf<TransaksiEntity>()
        val db = readableDatabase

        val cursor = db.rawQuery("SELECT * FROM $TABLE", null)

        while (cursor.moveToNext()) {
            val transaksi = TransaksiEntity(
                id = cursor.getInt(cursor.getColumnIndexOrThrow(COL_ID)),
                namaKendaraan = cursor.getString(cursor.getColumnIndexOrThrow(COL_NAMA)),
                harga = cursor.getString(cursor.getColumnIndexOrThrow(COL_HARGA)),
                tanggal = cursor.getString(cursor.getColumnIndexOrThrow(COL_TANGGAL)),
                status = cursor.getString(cursor.getColumnIndexOrThrow(COL_STATUS)),
                metodePembayaran = cursor.getString(cursor.getColumnIndexOrThrow(COL_METODE))
            )
            list.add(transaksi)
        }

        cursor.close()
        return list
    }
}
